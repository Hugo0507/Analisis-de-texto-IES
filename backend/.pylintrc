[MASTER]
ignore=migrations,venv,env,.git

[MESSAGES CONTROL]
disable=
    C0111,  # missing-docstring
    C0103,  # invalid-name
    R0903,  # too-few-public-methods
    R0913,  # too-many-arguments
    W0212,  # protected-access

[FORMAT]
max-line-length=120

[DESIGN]
max-args=10
max-attributes=15
