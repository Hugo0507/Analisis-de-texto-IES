[flake8]
max-line-length = 120
exclude =
    .git,
    __pycache__,
    */migrations/*,
    */venv/*,
    */env/*,
    .pytest_cache,
    htmlcov,
    .coverage
ignore =
    E203,  # whitespace before ':'
    W503,  # line break before binary operator
    E501,  # line too long (handled by black)
per-file-ignores =
    __init__.py:F401
