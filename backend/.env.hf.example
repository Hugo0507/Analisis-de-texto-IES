# ============================================================================
# HUGGING FACE SPACES - Environment Variables Template
# ============================================================================
# Copia estas variables en Settings → Variables and secrets de tu HF Space

# ============================================================================
# DJANGO CORE SETTINGS
# ============================================================================
# IMPORTANTE: Genera una SECRET_KEY segura con:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-here-minimum-50-characters-long-django-generated
DJANGO_SECRET_KEY=your-super-secret-key-here-minimum-50-characters-long-django-generated
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production

# ============================================================================
# ALLOWED HOSTS & SECURITY
# ============================================================================
# Actualiza con tu nombre de usuario de HF
DJANGO_ALLOWED_HOSTS=huggingface.co,*.huggingface.co,*.hf.space,Hugo0507-analisis-ies-backend.hf.space
SECURE_SSL_REDIRECT=True

# ============================================================================
# DATABASE - POSTGRESQL
# ============================================================================
# HF Spaces proporciona DATABASE_URL automáticamente cuando habilitas PostgreSQL
# No necesitas configurar esto manualmente, se crea automático
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Alternativamente, configuración manual (si no usas DATABASE_URL):
# DB_ENGINE=postgresql
# DB_NAME=analisis_transformacion_digital
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# ============================================================================
# REDIS CACHE (Opcional - habilitar en HF Space Settings)
# ============================================================================
# HF Spaces proporciona REDIS_URL automáticamente cuando habilitas Redis
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Actualiza con las URLs de tu frontend y backend
CORS_ALLOWED_ORIGINS=https://huggingface.co,https://Hugo0507-analisis-ies.hf.space,https://Hugo0507-analisis-ies-backend.hf.space
CSRF_TRUSTED_ORIGINS=https://huggingface.co,https://Hugo0507-analisis-ies-backend.hf.space

# ============================================================================
# GOOGLE DRIVE API (Opcional)
# ============================================================================
# Solo si necesitas integración con Google Drive
# GOOGLE_DRIVE_CREDENTIALS_FILE=/app/credentials/credentials.json
# GOOGLE_DRIVE_TOKEN_FILE=/app/credentials/token.json

# ============================================================================
# EMAIL CONFIGURATION (Opcional)
# ============================================================================
# Solo si necesitas enviar emails
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=tu-email@gmail.com
# EMAIL_HOST_PASSWORD=tu-app-password-aqui
# DEFAULT_FROM_EMAIL=tu-email@gmail.com

# ============================================================================
# ERROR MONITORING - SENTRY (Opcional)
# ============================================================================
# Solo si quieres monitoreo de errores con Sentry
# SENTRY_DSN=https://your-sentry-dsn-here@sentry.io/project-id
# ENVIRONMENT=production

# ============================================================================
# ADMIN USERS (Opcional)
# ============================================================================
# Formato: "Name:email@example.com,Name2:email2@example.com"
# DJANGO_ADMINS=Admin:admin@example.com

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
#
# 1. POSTGRESQL:
#    - Habilitar en: Space Settings → Persistent storage → PostgreSQL
#    - HF creará automáticamente DATABASE_URL
#
# 2. REDIS (Opcional):
#    - Habilitar en: Space Settings → Persistent storage → Redis
#    - HF creará automáticamente REDIS_URL
#
# 3. SECRET_KEY:
#    - NUNCA uses la default
#    - Genera una nueva con Django:
#      python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# 4. ALLOWED_HOSTS:
#    - Reemplaza "Hugo0507" con tu usuario de HF
#    - Reemplaza "analisis-ies-backend" con el nombre de tu Space
#
# 5. CORS_ALLOWED_ORIGINS:
#    - Agrega la URL de tu frontend si está en otro Space
#    - Agrega la URL de tu backend
#
# 6. Configurar en HF Space:
#    - Ve a: https://huggingface.co/spaces/[tu-usuario]/[tu-space]/settings
#    - Settings → Variables and secrets
#    - Agrega cada variable UNA POR UNA
#
