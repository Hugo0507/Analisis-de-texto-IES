# ============================================================================
# Backend - Environment Variables (Production)
# ============================================================================
# Copy this file to .env and fill in the actual values
# NEVER commit the .env file to version control!

# Django Configuration
# --------------------------------------------------------------------------
DJANGO_SECRET_KEY=your-secret-key-here-change-me-in-production
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com,api.your-domain.com
DJANGO_SECURE_SSL_REDIRECT=True
ENVIRONMENT=production

# Database Configuration (PostgreSQL for Render/Heroku)
# --------------------------------------------------------------------------
# Option 1: Use DATABASE_URL (Render, Heroku - Recommended)
# Render provides this automatically when you create a PostgreSQL database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option 2: Manual PostgreSQL Configuration (if not using DATABASE_URL)
DB_ENGINE=postgresql
DB_NAME=analisis_transformacion_digital
DB_USER=postgres
DB_PASSWORD=your-secure-database-password-here
DB_HOST=localhost
DB_PORT=5432

# Option 3: MySQL (Docker Compose Legacy - uncomment if needed)
# DB_ENGINE=mysql
# DB_NAME=analisis_transformacion_digital
# DB_USER=django_user
# DB_PASSWORD=your-secure-database-password-here
# DB_HOST=mysql
# DB_PORT=3306

# Redis Configuration
# --------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/1

# CORS Configuration
# --------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Email Configuration (for error notifications)
# --------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Django Admins (format: Name:email@example.com,Name2:email2@example.com)
DJANGO_ADMINS=Admin:admin@example.com

# Google Drive API Configuration
# --------------------------------------------------------------------------
GOOGLE_DRIVE_CREDENTIALS_FILE=/app/credentials/credentials.json
GOOGLE_DRIVE_TOKEN_FILE=/app/credentials/token.json

# Sentry Error Monitoring (optional)
# --------------------------------------------------------------------------
# Get your DSN from https://sentry.io/
SENTRY_DSN=

# Application Settings
# --------------------------------------------------------------------------
# Maximum upload size for documents (in bytes)
MAX_UPLOAD_SIZE=104857600

# Pipeline Configuration
# Number of parallel workers for pipeline execution
PIPELINE_WORKERS=4

# Cache TTL (in seconds)
CACHE_TTL=7200
