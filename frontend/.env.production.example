# ============================================================================
# Frontend - Production Environment Variables
# ============================================================================
# Copy this file to .env.production and fill in the actual values
# This file is used when building for production

# API Configuration
# --------------------------------------------------------------------------
# Backend API base URL (production)
REACT_APP_API_BASE_URL=https://api.your-domain.com/api/v1

# WebSocket Configuration
# --------------------------------------------------------------------------
# Backend WebSocket URL (production - use wss:// for secure websocket)
REACT_APP_WS_BASE_URL=wss://api.your-domain.com/ws

# Application Configuration
# --------------------------------------------------------------------------
# Application name
REACT_APP_NAME=Análisis de Transformación Digital

# Environment
REACT_APP_ENV=production

# Feature Flags
# --------------------------------------------------------------------------
# Enable/disable specific features
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_DEV_TOOLS=false

# Sentry Configuration (optional - for error tracking)
# --------------------------------------------------------------------------
# Get your DSN from https://sentry.io/
REACT_APP_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Google Analytics (optional)
# --------------------------------------------------------------------------
REACT_APP_GA_TRACKING_ID=UA-XXXXXXXXX-X
