# ============================================================================
# Frontend - Production Environment Variables (Vercel)
# ============================================================================
# These are the default production values
# Override them in Vercel Dashboard > Settings > Environment Variables

# API Configuration
# --------------------------------------------------------------------------
# Backend API base URL (Hugging Face Spaces)
REACT_APP_API_BASE_URL=https://hugo0507-analisis-ies-backend.hf.space/api/v1

# WebSocket Configuration
# --------------------------------------------------------------------------
# Backend WebSocket URL
REACT_APP_WS_BASE_URL=wss://hugo0507-analisis-ies-backend.hf.space/ws

# Application Configuration
# --------------------------------------------------------------------------
REACT_APP_NAME=Análisis de Transformación Digital
REACT_APP_ENV=production

# Feature Flags
# --------------------------------------------------------------------------
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_DEV_TOOLS=false

# Optional: Sentry, Google Analytics, etc.
# --------------------------------------------------------------------------
# REACT_APP_SENTRY_DSN=
# REACT_APP_GA_TRACKING_ID=
