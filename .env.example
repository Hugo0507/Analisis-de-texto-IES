# ==================== CONFIGURACIÓN DE LA APLICACIÓN ====================
# Copiar este archivo como .env y ajustar los valores

# ==================== GOOGLE DRIVE ====================
# ID de la carpeta raíz en Google Drive
GOOGLE_DRIVE_FOLDER_ID=1tDUZ4PnQen_lSr6z4ZALji2zdtrJf-sS

# Rutas de credenciales de Google
CREDENTIALS_PATH=credentials.json
TOKEN_PATH=token.json

# ==================== LOGGING ====================
# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Directorio donde se guardarán los logs
LOG_DIR=logs

# ==================== CACHÉ ====================
# Habilitar sistema de caché
CACHE_ENABLED=True

# Directorio de caché local
CACHE_DIR=cache

# ==================== PROCESAMIENTO NLP ====================
# Idioma por defecto para procesamiento
DEFAULT_LANGUAGE=english

# Aplicar stemming por defecto
USE_STEMMING=True

# Longitud mínima de palabras
MIN_WORD_LENGTH=3

# ==================== MACHINE LEARNING ====================
# Número de clusters por defecto para K-Means
N_CLUSTERS_DEFAULT=3

# Número de tópicos por defecto para LDA
N_TOPICS_DEFAULT=5

# Número de palabras por tópico
N_WORDS_PER_TOPIC=10

# ==================== VISUALIZACIÓN ====================
# Número máximo de palabras en nube de palabras
MAX_PALABRAS_NUBE=100

# Top N palabras para mostrar en análisis
TOP_N_PALABRAS=20

# Esquema de colores para visualizaciones
COLOR_SCHEME=Blues
COLORMAP_WORDCLOUD=viridis

# Dimensiones de nube de palabras
ANCHO_NUBE_PALABRAS=1200
ALTO_NUBE_PALABRAS=600

# ==================== DIRECTORIOS ====================
# Directorio de datos
DATA_DIR=data

# Directorio de salida
OUTPUT_DIR=output

# ==================== STREAMLIT ====================
# Puerto de la aplicación Streamlit
STREAMLIT_PORT=8501

# Servidor de Streamlit
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ==================== SEGURIDAD ====================
# Clave secreta para la aplicación (generar una nueva)
# SECRET_KEY=tu-clave-secreta-aqui

# ==================== DESARROLLO ====================
# Modo debug (True/False)
DEBUG=False

# Entorno (development, staging, production)
ENVIRONMENT=development
